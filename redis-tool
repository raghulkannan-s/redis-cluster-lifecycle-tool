#!/bin/bash
# redis-tool — CLI entrypoint for Redis Cluster lifecycle operations.
# Command implementations live in lib/*.sh; network/config in lib/config.sh.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/logging.sh"
source "$SCRIPT_DIR/lib/runtime.sh"
source "$SCRIPT_DIR/lib/ssh.sh"
source "$SCRIPT_DIR/lib/cluster.sh"
source "$SCRIPT_DIR/lib/setup.sh"
source "$SCRIPT_DIR/lib/provision.sh"
source "$SCRIPT_DIR/lib/data.sh"
source "$SCRIPT_DIR/lib/upgrade.sh"
source "$SCRIPT_DIR/lib/verify.sh"
source "$SCRIPT_DIR/lib/rollback.sh"

CMD="${1:-}"
shift || true

case "$CMD" in
    setup)
        check_runtime_prereqs
        cmd_setup "$@"
        ;;

    provision)
        check_prereqs
        cmd_provision "$@"
        ;;

    data)
        check_prereqs
        SUBCMD="${1:-}"
        shift || true
        case "$SUBCMD" in
            seed) cmd_data_seed "$@" ;;
            verify) cmd_data_verify "$@" ;;
            *)
                echo "Usage: redis-tool data {seed|verify} [options]"
                exit 1
                ;;
        esac
        ;;

    status)
        check_prereqs
        cmd_status "$@"
        ;;

    upgrade)
        check_prereqs
        cmd_upgrade "$@"
        ;;

    rollback)
        check_prereqs
        cmd_rollback "$@"
        ;;

    verify)
        check_prereqs
        cmd_verify_full "$@"
        ;;

    *)
        cat <<'EOF'
Usage: redis-tool <command> [options]

Commands:
  setup       Start container infrastructure (6 SSH nodes)
  provision   Install Redis and form the cluster (requires setup)
  data seed   Seed test data into the cluster
  data verify Verify data integrity
  status      Show cluster status
  upgrade     Perform a rolling upgrade
  verify      Full cluster verification (--full)
  rollback    Rollback to a previous version

Workflow:
  1. ./redis-tool setup
  2. ./redis-tool provision --version 7.0.15 --masters 3 --replicas-per-master 1
  3. ./redis-tool data seed --keys 1000

Examples:
  ./redis-tool setup
  ./redis-tool setup --force
  ./redis-tool provision --version 7.0.15 --masters 3 --replicas-per-master 1
  ./redis-tool upgrade --target-version 7.2.6 --strategy rolling
EOF
        exit 1
        ;;
esac
