#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/logging.sh"
source "$SCRIPT_DIR/lib/runtime.sh"
source "$SCRIPT_DIR/lib/ssh.sh"
source "$SCRIPT_DIR/lib/cluster.sh"
source "$SCRIPT_DIR/lib/provision.sh"
source "$SCRIPT_DIR/lib/data.sh"
source "$SCRIPT_DIR/lib/upgrade.sh"
source "$SCRIPT_DIR/lib/verify.sh"
source "$SCRIPT_DIR/lib/rollback.sh"

check_prereqs

CMD="${1:-}"
shift || true

case "$CMD" in

    provision)
        cmd_provision "$@"
        ;;

    data)
        SUBCMD="${1:-}"
        shift || true

        case "$SUBCMD" in
            seed) cmd_data_seed "$@" ;;
            verify) cmd_data_verify "$@" ;;
            *) exit 1 ;;
        esac
        ;;

    status)
        cmd_status "$@"
        ;;

    upgrade)
        cmd_upgrade "$@"
        ;;

    rollback)
        cmd_rollback "$@"
        ;;

    verify)
        cmd_verify_full "$@"
        ;;

    *)
        exit 1
        ;;
esac

